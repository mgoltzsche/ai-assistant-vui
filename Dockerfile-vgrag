FROM python:3.14-slim-trixie
RUN python3 -m pip install \
	uvicorn==0.46.0 \
	fastapi==0.136.1 \
	milvus-lite==2.5.1 \
	vector-graph-rag[hf]==0.1.4 \
	einops==0.8.2 \
	trafilatura==2.0.0 \
	markitdown[pdf,docx]==0.1.5
ENV VGRAG_OPENAI_BASE_URL=http://127.0.0.1:8080/v1 \
	VGRAG_OPENAI_API_KEY=none \
	VGRAG_LLM_MODEL=qwen3-4b \
	VGRAG_EMBEDDING_MODEL=intfloat/multilingual-e5-small \
	VGRAG_EMBEDDING_MODEL_DIMENSION=384
ENTRYPOINT ["uvicorn", "vector_graph_rag.api.app:app"]
CMD ["--host", "0.0.0.0", "--port", "8000"]
